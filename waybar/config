{
    "layer": "top",
    "position": "top",
    "height": 48,
  
    "margin-top": 1,
    "margin-left": 1,
    "margin-right": 1,
    "spacing": 1,
  
    "modules-left": ["hyprland/workspaces", "hyprland/submap", "hyprland/window"],
    "modules-center": ["clock"],
    "modules-right": [
      "pulseaudio",
      "custom/cpuinfo",
      "cpu",
      "custom/gpuinfo",
      "memory",
      "network",
      "bluetooth",
      "idle_inhibitor",
      "custom/cliphist",
      "wlr/taskbar",
      "custom/powermenu"
    ],
  
    "hyprland/submap": {
      "format": "´üö´äà {}"
    },
  
    "hyprland/workspaces": {
      "disable-scroll": true,
      "all-outputs": false,
      "disable-markup": false,
      "format": "{icon}",
      "format-icons": {
        "1": "1 <span font='FiraCode Nerd Font Mono 18'>´äá¾▒é¼</span>",
        "2": "2 <span font='FiraCode Nerd Font Mono 18'>¾▒é¼</span>",
        "3": "3 <span font='FiraCode Nerd Font Mono 18'>¾▒é¼</span>",
        "4": "4 <span font='FiraCode Nerd Font Mono 18'>¾▒é¼</span>",
        "5": "5 <span font='FiraCode Nerd Font Mono 18'>¾▒é¼</span>"
      }
    },
  
    "hyprland/window": {
      "max-length": 60,
      "tooltip": false
    },
  
    "clock": {
      "format": "{:%I:%M %p}",
      "format-alt": "{:%R ¾░â¡ %d┬À%m┬À%y}",
      "tooltip-format": "<tt>{calendar}</tt>",
      "calendar": {
        "mode": "month",
        "mode-mon-col": 3,
        "on-scroll": 1,
        "on-click-right": "mode",
        "format": {
          "months": "<span color='#E9EEF5'><b>{}</b></span>",
          "weekdays": "<span color='#C7D2E3'><b>{}</b></span>",
          "today": "<span color='#6CB6FF'><b>{}</b></span>"
        }
      },
      "actions": {
        "on-click-right": "mode",
        "on-click-forward": "tz_up",
        "on-click-backward": "tz_down",
        "on-scroll-up": "shift_up",
        "on-scroll-down": "shift_down"
      }
    },
  
    "pulseaudio": {
      "format": "{icon} {volume}",
      "format-muted": "´¬Ç",
      "on-click": "pavucontrol -t 3",
      "on-click-middle": "$HOME/.config/hypr/scripts/volumecontrol -o m",
      "on-scroll-up": "$HOME/.config/hypr/scripts/volumecontrol -o i",
      "on-scroll-down": "$HOME/.config/hypr/scripts/volumecontrol -o d",
      "tooltip-format": "{icon} {desc} // {volume}%",
      "scroll-step": 5,
      "format-icons": {
        "headphone": "´ÇÑ",
        "hands-free": "´ÇÑ",
        "headset": "´ÇÑ",
        "phone": "´éò",
        "portable": "´éò",
        "car": "´å╣",
        "default": ["´ÇĞ", "´Çğ", "´Ç¿"]
      }
    },
  
    "cpu": {
      "interval": 10,
      "format": "¾░ıø {usage}%",
      "format-alt": "{icon0}{icon1}{icon2}{icon3}",
      "format-icons": ["Ôûü", "Ôûé", "Ôûâ", "Ôûä", "Ôûà", "Ôûå", "Ôûç", "Ôûê"]
    },
  
    "memory": {
      "states": {
        "c": 90,
        "h": 60,
        "m": 30
      },
      "interval": 30,
      "format": "¾░¥å {used}GB",
      "format-m": "¾░¥à {used}GB",
      "format-h": "¾░ôà {used}GB",
      "format-c": "´Éí {used}GB",
      "format-alt": "¾░¥å {percentage}%",
      "max-length": 10,
      "tooltip": true,
      "tooltip-format": "¾░¥å {percentage}%\n¯ëĞ {used:0.1f}GB/{total:0.1f}GB"
    },
  
    "network": {
      "tooltip": true,
      "format-wifi": "´ç½ ",
      "format-ethernet": "¾░êÇ ",
      "tooltip-format": "Network: <big><b>{essid}</b></big>\nSignal strength: <b>{signaldBm}dBm ({signalStrength}%)</b>\nFrequency: <b>{frequency}MHz</b>\nInterface: <b>{ifname}</b>\nIP: <b>{ipaddr}/{cidr}</b>\nGateway: <b>{gwaddr}</b>\nNetmask: <b>{netmask}</b>",
      "format-linked": "¾░êÇ {ifname} (No IP)",
      "format-disconnected": "¾░û¬ ",
      "tooltip-format-disconnected": "Disconnected",
      "format-alt": "<span foreground='#8FE7D5'>´ÇÖ {bandwidthDownBytes}</span> <span foreground='#FFD27A'>´éô {bandwidthUpBytes}</span>",
      "interval": 2
    },
  
    "bluetooth": {
      "format": "",
      "format-disabled": "",
      "format-connected": "´èô {num_connections}",
      "format-connected-battery": "{icon} {num_connections}",
      "format-icons": ["¾░Ñç", "¾░ñ¥", "¾░ñ┐", "¾░ÑÇ", "¾░Ñü", "¾░Ñé", "¾░Ñâ", "¾░Ñä", "¾░Ñà", "¾░Ñå", "¾░Ñê"],
      "tooltip-format": "{controller_alias}\n{num_connections} connected",
      "tooltip-format-connected": "{controller_alias}\n{num_connections} connected\n\n{device_enumerate}",
      "tooltip-format-enumerate-connected": "{device_alias}",
      "tooltip-format-enumerate-connected-battery": "{device_alias}\t{icon} {device_battery_percentage}%"
    },
  
    "idle_inhibitor": {
      "format": "{icon}",
      "tooltip": true,
      "format-icons": {
        "activated": "¾░Ñö",
        "deactivated": "´É║"
      },
      "on-click-right": "hyprlock"
    },
  
    "custom/cliphist": {
      "format": "´â¬{}",
      "exec": "echo ; echo ¾░àç clipboard history",
      "on-click": "sleep 0.1 && $HOME/.config/hypr/scripts/cliphist c",
      "on-click-right": "sleep 0.1 && $HOME/.config/hypr/scripts/cliphist d",
      "on-click-middle": "sleep 0.1 && $HOME/.config/hypr/scripts/cliphist w",
      "interval": 86400,
      "tooltip": true
    },
  
    "wlr/taskbar": {
      "format": "{icon}",
      "icon-size": 16,
      "icon-theme": "Tela-dark",
      "spacing": 0,
      "tooltip-format": "{title}",
      "on-click": "activate",
      "on-click-middle": "close",
      "ignore-list": ["Alacritty"],
      "app_ids-mapping": {
        "firefoxdeveloperedition": "firefox-developer-edition"
      }
    },
  
    "custom/cpuinfo": {
      "exec": "$HOME/.config/waybar/scripts/cpu_info",
      "return-type": "json",
      "format": "{text}",
      "interval": 5,
      "tooltip": true,
      "max-length": 1000
    },
  
    "custom/gpuinfo": {
      "exec": "$HOME/.config/waybar/scripts/gpu_info --use nvidia",
      "return-type": "json",
      "format": "{text}",
      "interval": 5,
      "tooltip": true,
      "max-length": 1000
    },
  
    "custom/powermenu": {
      "on-click": "$HOME/.config/waybar/scripts/powermenu",
      "format": "<span font='FiraCode Nerd Font Mono 18'>{icon}</span>  {text}",
      "format-icons": ["´Çæ"],
      "interval": 3600,
      "escape": true
    }
  }
  